# Stripe secret key for the /api/checkout serverless function.
# Use a TEST-mode key (sk_test_...) until launch, then switch to live (sk_live_...).
# Set it in the Vercel project (Settings → Environment Variables) and, for local
# `vercel dev`, copy this file to `.env` and fill it in. Never commit real keys.
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Order + onboarding emails (Resend) ────────────────────────────────────────
# Used by BOTH /api/stripe-webhook (order team-notice + customer receipt) and
# /api/intake (the post-purchase onboarding intake → emailed to the team with the
# logo attached). Generate a key at https://resend.com/api-keys. Without it those
# endpoints skip the email (orders/intake still complete). Set in Vercel + .env.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where team emails (order notices + intake) go (comma-separated for multiple).
ORDER_NOTIFY_TO=hello@saasassins.com

# Sender for all of the above. The DOMAIN must be verified in Resend
# (https://resend.com/domains) or the send is rejected. The SaaSassins
# verified sending domain is mail.saasassinsdev.com.
ORDER_NOTIFY_FROM=PolishPoint Orders <orders@mail.saasassinsdev.com>

# ── Demo concierge (AI chat) — for the /api/assistant serverless function ──────
# OpenAI API key for the prospect-facing demo concierge. Lives ONLY here (server
# env) — never in the browser. Without it, /api/assistant returns 503 and the
# frontend silently falls back to its grounded local stub, so the demo keeps
# working. Set it in the Vercel project (and .env for local `vercel dev`).
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional model override. Default is gpt-4o-mini — cheap + fast, ample for the
# concierge's short, grounded answers.
OPENAI_MODEL=gpt-4o-mini

# Optional kill switch. Set to 'false' to disable the live concierge without a
# redeploy (the frontend falls back to its local stub). Any other value = enabled.
DEMO_CHAT_ENABLED=true
