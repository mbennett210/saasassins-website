# ──────────────────────────────────────────────────────────────────────────────
# Frontend env (Vite — exposed to the browser)
# ──────────────────────────────────────────────────────────────────────────────
# These VITE_-prefixed vars are bundled into the frontend at build time.
# Copy to `.env.local` for local dev (.env.local is gitignored).
#
# When unset, the matching frontend adapter falls into a local stub mode that
# simulates network calls — useful for UI iteration without a backend.

# Twilio adapter — see app/src/lib/twilio.js
VITE_TWILIO_BACKEND_URL=

# Email adapter — see app/src/lib/email.js
# Points at the deployment backend that wraps Resend (typically a Vercel API
# route mounted at /api). Common values:
#   - dev (separate backend project):  http://localhost:8787/api
#   - prod (same Vercel project):      /api
VITE_EMAIL_BACKEND_URL=

# Push adapter — see app/src/lib/push.js
# Points at the deployment backend's /api/push/* routes. When unset, push.js
# runs in local stub mode (subscriptions live in memory; the test-push button
# fires a local Notification on the current device).
VITE_PUSH_BACKEND_URL=

# VAPID public key for Web Push subscription. Generated once via
#   npx web-push generate-vapid-keys
# The matching private key (VAPID_PRIVATE_KEY) lives in backend env only.
# Safe to expose in the frontend bundle.
VITE_VAPID_PUBLIC_KEY=

# Demo concierge adapter — see app/src/lib/demoAssistant.js
# Points at the OpenAI proxy (api/assistant.js). When unset, the concierge runs
# in a grounded LOCAL STUB (no key, no network) — ideal for `dev:demo`. Set it in
# the Vercel demo deployment to light up the live LLM (same-origin):
#   VITE_ASSISTANT_BACKEND_URL=/api/assistant
# NOTE: unlike the Twilio/email/push adapters, this is intentionally NOT pinned to
# stub in the demo build. The concierge is a read-only Q&A endpoint (like the
# Stripe checkout), so it's allowed to reach its backend even when VITE_DEMO_MODE
# is true. It still falls back to the local stub if the proxy errors.
VITE_ASSISTANT_BACKEND_URL=

# ──────────────────────────────────────────────────────────────────────────────
# Backend env (NOT exposed to the browser)
# ──────────────────────────────────────────────────────────────────────────────
# These are consumed by the deployment backend (Vercel API routes / Cloudflare
# Workers / etc.) that this frontend calls. They are NEVER prefixed VITE_ and
# NEVER referenced from app/src/. Put them in your hosting platform's secret
# manager — never commit a populated copy of this file.

# ── System transactional email (Resend) ────────────────────────────────────
# Resend account API key. Generate at https://resend.com/api-keys.
RESEND_API_KEY=re_your_key_here

# Verified sending subdomain (must be added + verified in Resend before sends
# leave stub mode in production). Recommended pattern is a dedicated subdomain
# such as `mail.<your-domain>` so app email reputation is isolated from
# marketing or general business email.
RESEND_VERIFIED_DOMAIN=mail.example.com

# Default From for system-originated email (invitations, reminders, billing).
# Backend validates this against RESEND_VERIFIED_DOMAIN on every send.
RESEND_DEFAULT_FROM="Your Company <hello@mail.example.com>"

# Optional Reply-To override for system emails. When unset, replies route to
# whatever Reply-To the caller passed (typically the inviter's address).
RESEND_DEFAULT_REPLY_TO=

# Inbound webhook signing secret (used in Phase 4c — verifies that inbound
# email payloads actually came from Resend, not a forger).
RESEND_INBOUND_SECRET=

# ── Per-user Connected Inboxes (Phase 3 — placeholders) ────────────────────
# Filled in once Phase 3 (per-user OAuth + SMTP) lands. Documented here so
# the deployment env stays in one place.

# Google OAuth (Gmail / Workspace)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_PUBSUB_TOPIC=

# Microsoft OAuth (Outlook / 365)
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_TENANT=common

# Encryption key for stored tokens / SMTP passwords (32-byte random, AES-GCM).
# Generate with: `openssl rand -base64 32`
INBOX_TOKEN_ENCRYPTION_KEY=

# Public base URL of this app, used to build OAuth redirect URIs and inbound
# Reply-To addresses (e.g. reply+<conversationId>@inbound.<verified-domain>).
INBOX_INBOUND_BASE_URL=https://app.example.com

# ── Web Push (mobile + desktop notifications) ──────────────────────────────
# VAPID keypair. Public key is also exposed to the frontend as
# VITE_VAPID_PUBLIC_KEY (above). Private key MUST stay server-side.
# Generate both at once: `npx web-push generate-vapid-keys`.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Subject identifier for push messages — either a `mailto:` address or an
# `https://` URL identifying the operator. Required by the Web Push spec.
VAPID_SUBJECT=mailto:office@example.com

# ── Demo concierge (AI chat) ───────────────────────────────────────────────
# OpenAI key + options for the /api/assistant proxy. Documented in full in the
# repo-root .env.example (next to STRIPE_SECRET_KEY), since api/ lives there.
#   OPENAI_API_KEY, OPENAI_MODEL (default gpt-4o-mini), DEMO_CHAT_ENABLED
