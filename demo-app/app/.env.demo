# Vite mode file — loaded for `--mode demo` (npm run dev:demo / build:demo / preview:demo).
# Turns on the marketing-demo commerce layer and mounts the SPA under /polishpoint.
# The default (no-mode) build leaves these unset, so per-client product builds
# stay at base '/' with no demo/commerce UI compiled in.
VITE_DEMO_MODE=true
VITE_BASE_PATH=/polishpoint/
